{
  "template_name": "ifc_core_catalog_v1",
  "extractor_version": "1.0.0",
  "description": "Base template — one CSV row per IFC file with CDE_IFC, CORE metadata and per-class metrics.",
  "metadata": {
    "author":               "GeoInnova",
    "contact":              "patricio.soriano@geoinnova.org",
    "created_at":           "2026-06-26",
    "updated_at":           "2026-06-26",
    "template_version":     "1.0.0",
    "min_extractor_version":"1.0.0",
    "ifc_versions":         ["IFC2X3", "IFC4", "IFC4X3"],
    "language":             "en",
    "license":              "proprietary",
    "tags":                 ["IFC", "BIM", "catalog", "GIS", "QGIS"]
  },
  "fields": [
    {"name": "file_name",               "enabled": true, "group": "File",              "alias": "File name",               "computed": false, "ifc_source": null,                                      "description": "IFC filename without path"},
    {"name": "file_path",               "enabled": true, "group": "File",              "alias": "File path",               "computed": false, "ifc_source": null,                                      "description": "Full path to the IFC file"},
    {"name": "document_format",         "enabled": true, "group": "File",              "alias": "Document format",         "computed": false, "ifc_source": null,                                      "description": "Always IFC"},
    {"name": "file_extension",          "enabled": true, "group": "File",              "alias": "File extension",          "computed": false, "ifc_source": null,                                      "description": "File extension (.ifc, .ifczip, ...)"},
    {"name": "file_size_mb",            "enabled": true, "group": "File",              "alias": "File size (MB)",          "computed": false, "ifc_source": null,                                      "description": "File size in megabytes"},
    {"name": "file_hash",               "enabled": true, "group": "File",              "alias": "File hash (MD5)",         "computed": true,  "ifc_source": null,                                      "description": "MD5 of the first 64 KB"},
    {"name": "file_created",            "enabled": true, "group": "File",              "alias": "File created",            "computed": false, "ifc_source": null,                                      "description": "Filesystem creation timestamp"},
    {"name": "file_modified",           "enabled": true, "group": "File",              "alias": "File modified",           "computed": false, "ifc_source": null,                                      "description": "Filesystem last-modified timestamp"},
    {"name": "ifc_version",             "enabled": true, "group": "IFC Header",        "alias": "IFC version",             "computed": false, "ifc_source": "FILE_DESCRIPTION",                        "description": "IFC schema version string (e.g. IFC4)"},
    {"name": "schema_identifier",       "enabled": true, "group": "IFC Header",        "alias": "Schema identifier",       "computed": false, "ifc_source": "FILE_SCHEMA",                             "description": "Full schema identifier from the header"},
    {"name": "file_description",        "enabled": true, "group": "IFC Header",        "alias": "File description",        "computed": false, "ifc_source": "FILE_DESCRIPTION",                        "description": "Description from FILE_DESCRIPTION header"},
    {"name": "file_timestamp",          "enabled": true, "group": "IFC Header",        "alias": "File timestamp",          "computed": false, "ifc_source": "FILE_NAME.time_stamp",                    "description": "Timestamp from FILE_NAME header"},
    {"name": "author",                  "enabled": true, "group": "IFC Header",        "alias": "Author",                  "computed": false, "ifc_source": "FILE_NAME.author",                        "description": "Author(s) from FILE_NAME header"},
    {"name": "organization",            "enabled": true, "group": "IFC Header",        "alias": "Organization",            "computed": false, "ifc_source": "FILE_NAME.organization",                  "description": "Organization from FILE_NAME header"},
    {"name": "originating_system",      "enabled": true, "group": "IFC Header",        "alias": "Originating system",      "computed": false, "ifc_source": "FILE_NAME.originating_system",            "description": "Authoring tool / originating system"},
    {"name": "preprocessor_version",    "enabled": true, "group": "IFC Header",        "alias": "Preprocessor version",    "computed": false, "ifc_source": "FILE_NAME.preprocessor_version",          "description": "Preprocessor/exporter version"},
    {"name": "authorization",           "enabled": true, "group": "IFC Header",        "alias": "Authorization",           "computed": false, "ifc_source": "FILE_NAME.authorization",                 "description": "Authorization string from FILE_NAME"},
    {"name": "project_name",            "enabled": true, "group": "Project",           "alias": "Project name",            "computed": false, "ifc_source": "IfcProject.Name",                         "description": "IfcProject.Name"},
    {"name": "project_globalid",        "enabled": true, "group": "Project",           "alias": "Project GlobalId",        "computed": false, "ifc_source": "IfcProject.GlobalId",                     "description": "IfcProject.GlobalId"},
    {"name": "project_description",     "enabled": true, "group": "Project",           "alias": "Project description",     "computed": false, "ifc_source": "IfcProject.Description",                  "description": "IfcProject.Description"},
    {"name": "project_phase",           "enabled": true, "group": "Project",           "alias": "Project phase",           "computed": false, "ifc_source": "IfcProject.Phase",                        "description": "IfcProject.Phase"},
    {"name": "site_name",               "enabled": true, "group": "Location",          "alias": "Site name",               "computed": false, "ifc_source": "IfcSite.Name",                            "description": "IfcSite.Name"},
    {"name": "building_name",           "enabled": true, "group": "Location",          "alias": "Building name",           "computed": false, "ifc_source": "IfcBuilding.Name",                        "ifc4x3_note": "IfcBuilding deprecated in IFC4X3; extractor falls back to IfcFacility",        "description": "IfcBuilding.Name"},
    {"name": "epsg",                    "enabled": true, "group": "Location",          "alias": "EPSG code",               "computed": true,  "ifc_source": "IfcCoordinateReferenceSystem",             "min_ifc_version": "IFC4",                                                                     "description": "EPSG code parsed from IfcCoordinateReferenceSystem"},
    {"name": "crs_name",                "enabled": true, "group": "Location",          "alias": "CRS name",                "computed": false, "ifc_source": "IfcCoordinateReferenceSystem.Name",        "min_ifc_version": "IFC4",                                                                     "description": "IfcCoordinateReferenceSystem.Name"},
    {"name": "latitude",                "enabled": true, "group": "Location",          "alias": "Latitude (deg)",          "computed": true,  "ifc_source": "IfcSite.RefLatitude",                     "description": "IfcSite.RefLatitude converted to decimal degrees"},
    {"name": "longitude",               "enabled": true, "group": "Location",          "alias": "Longitude (deg)",         "computed": true,  "ifc_source": "IfcSite.RefLongitude",                    "description": "IfcSite.RefLongitude converted to decimal degrees"},
    {"name": "easting",                 "enabled": true, "group": "Location",          "alias": "Easting (m)",             "computed": false, "ifc_source": "IfcMapConversion.Eastings",               "min_ifc_version": "IFC4",                                                                     "description": "IfcMapConversion.Eastings"},
    {"name": "northing",                "enabled": true, "group": "Location",          "alias": "Northing (m)",            "computed": false, "ifc_source": "IfcMapConversion.Northings",              "min_ifc_version": "IFC4",                                                                     "description": "IfcMapConversion.Northings"},
    {"name": "elevation",               "enabled": true, "group": "Location",          "alias": "Elevation (m)",           "computed": false, "ifc_source": "IfcMapConversion.OrthogonalHeight",       "min_ifc_version": "IFC4",                                                                     "description": "IfcMapConversion.OrthogonalHeight"},
    {"name": "is_georeferenced",        "enabled": true, "group": "Location",          "alias": "Is georeferenced",        "computed": true,  "ifc_source": "IfcMapConversion",                        "min_ifc_version": "IFC4",                                                                     "description": "True when IfcMapConversion is present"},
    {"name": "detected_domain",         "enabled": true, "group": "Domain",            "alias": "Detected domain",         "computed": true,  "ifc_source": null,                                      "description": "Heuristic domain (Building, Infrastructure, MEP...)"},
    {"name": "detected_discipline",     "enabled": true, "group": "Domain",            "alias": "Detected discipline",     "computed": true,  "ifc_source": null,                                      "description": "Heuristic discipline from class composition"},
    {"name": "site_count",              "enabled": true, "group": "Spatial Structure", "alias": "Site count",              "computed": true,  "ifc_source": "IfcSite",                                 "description": "Number of IfcSite entities"},
    {"name": "building_count",          "enabled": true, "group": "Spatial Structure", "alias": "Building count",          "computed": true,  "ifc_source": "IfcBuilding",                             "ifc4x3_note": "IfcBuilding deprecated in IFC4X3; count includes IfcFacility subtypes",          "description": "Number of IfcBuilding entities"},
    {"name": "storey_count",            "enabled": true, "group": "Spatial Structure", "alias": "Storey count",            "computed": true,  "ifc_source": "IfcBuildingStorey",                       "ifc4x3_note": "IfcBuildingStorey deprecated in IFC4X3; extractor falls back to IfcFacilityPart","description": "Number of IfcBuildingStorey entities"},
    {"name": "space_count",             "enabled": true, "group": "Spatial Structure", "alias": "Space count",             "computed": true,  "ifc_source": "IfcSpace",                                "description": "Number of IfcSpace entities"},
    {"name": "zone_count",              "enabled": true, "group": "Spatial Structure", "alias": "Zone count",              "computed": true,  "ifc_source": "IfcZone",                                 "description": "Number of IfcZone entities"},
    {"name": "system_count",            "enabled": true, "group": "Spatial Structure", "alias": "System count",            "computed": true,  "ifc_source": "IfcSystem",                               "description": "Number of IfcSystem entities"},
    {"name": "total_entities",          "enabled": true, "group": "Model Statistics",  "alias": "Total entities",          "computed": true,  "ifc_source": null,                                      "description": "Total entity count in the IFC file"},
    {"name": "total_objects",           "enabled": true, "group": "Model Statistics",  "alias": "Total objects",           "computed": true,  "ifc_source": "IfcObject",                               "description": "Number of IfcObject entities"},
    {"name": "total_physical_elements", "enabled": true, "group": "Model Statistics",  "alias": "Total physical elements", "computed": true,  "ifc_source": "IfcElement",                              "description": "Number of IfcElement entities"},
    {"name": "distinct_ifc_classes",    "enabled": true, "group": "Model Statistics",  "alias": "Distinct IFC classes",    "computed": true,  "ifc_source": null,                                      "description": "Number of distinct entity types present"},
    {"name": "bbox_width",              "enabled": true, "group": "Geometry",          "alias": "Bounding box width (m)",  "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "Model bounding box width"},
    {"name": "bbox_depth",              "enabled": true, "group": "Geometry",          "alias": "Bounding box depth (m)",  "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "Model bounding box depth"},
    {"name": "bbox_height",             "enabled": true, "group": "Geometry",          "alias": "Bounding box height (m)", "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "Model bounding box height"},
    {"name": "footprint_area",          "enabled": true, "group": "Geometry",          "alias": "Footprint area (m2)",     "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "Projected footprint area"},
    {"name": "gross_floor_area",        "enabled": true, "group": "Geometry",          "alias": "Gross floor area (m2)",   "computed": true,  "ifc_source": "IfcElementQuantity.GrossFloorArea",       "description": "Sum of GrossFloorArea from QuantitySets"},
    {"name": "net_floor_area",          "enabled": true, "group": "Geometry",          "alias": "Net floor area (m2)",     "computed": true,  "ifc_source": "IfcElementQuantity.NetFloorArea",         "description": "Sum of NetFloorArea from QuantitySets"},
    {"name": "gross_volume",            "enabled": true, "group": "Geometry",          "alias": "Gross volume (m3)",       "computed": true,  "ifc_source": "IfcElementQuantity.GrossVolume",          "description": "Total gross volume from QuantitySets"},
    {"name": "net_volume",              "enabled": true, "group": "Geometry",          "alias": "Net volume (m3)",         "computed": true,  "ifc_source": "IfcElementQuantity.NetVolume",            "description": "Total net volume from QuantitySets"},
    {"name": "total_length",            "enabled": true, "group": "Geometry",          "alias": "Total length (m)",        "computed": true,  "ifc_source": "IfcElementQuantity.Length",               "description": "Sum of all linear element lengths"},
    {"name": "material_count",          "enabled": true, "group": "Materials",         "alias": "Material count",          "computed": true,  "ifc_source": "IfcMaterial",                             "description": "Number of IfcMaterial entities"},
    {"name": "dominant_material",       "enabled": true, "group": "Materials",         "alias": "Dominant material",       "computed": true,  "ifc_source": "IfcMaterial.Name",                        "description": "Most frequently referenced material name"},
    {"name": "propertyset_count",       "enabled": true, "group": "BIM Quality",       "alias": "PropertySet count",       "computed": true,  "ifc_source": "IfcPropertySet",                          "description": "Number of IfcPropertySet entities"},
    {"name": "quantityset_count",       "enabled": true, "group": "BIM Quality",       "alias": "QuantitySet count",       "computed": true,  "ifc_source": "IfcElementQuantity",                      "description": "Number of IfcElementQuantity entities"},
    {"name": "classification_count",    "enabled": true, "group": "BIM Quality",       "alias": "Classification count",    "computed": true,  "ifc_source": "IfcClassification",                       "description": "Number of IfcClassification entities"},
    {"name": "has_geometry",            "enabled": true, "group": "BIM Quality",       "alias": "Has geometry",            "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "True when at least one element has geometry"},
    {"name": "has_quantities",          "enabled": true, "group": "BIM Quality",       "alias": "Has quantities",          "computed": true,  "ifc_source": "IfcElementQuantity",                      "description": "True when at least one QuantitySet exists"},
    {"name": "has_property_sets",       "enabled": true, "group": "BIM Quality",       "alias": "Has property sets",       "computed": true,  "ifc_source": "IfcPropertySet",                          "description": "True when at least one PropertySet exists"},
    {"name": "has_materials",           "enabled": true, "group": "BIM Quality",       "alias": "Has materials",           "computed": true,  "ifc_source": "IfcMaterial",                             "description": "True when at least one IfcMaterial exists"},
    {"name": "has_classifications",     "enabled": true, "group": "BIM Quality",       "alias": "Has classifications",     "computed": true,  "ifc_source": "IfcClassification",                       "description": "True when at least one IfcClassification exists"},
    {"name": "has_spatial_structure",   "enabled": true, "group": "BIM Quality",       "alias": "Has spatial structure",   "computed": true,  "ifc_source": "IfcBuildingStorey | IfcSpace",            "description": "True when the model has storeys or spaces"},
    {"name": "geometry_completion_pct", "enabled": true, "group": "BIM Quality",       "alias": "Geometry completion %",   "computed": true,  "ifc_source": "IfcShapeRepresentation",                  "description": "% of IfcElement with geometry representation"},
    {"name": "property_completion_pct", "enabled": true, "group": "BIM Quality",       "alias": "Property completion %",   "computed": true,  "ifc_source": "IfcRelDefinesByProperties",               "description": "% of IfcElement with at least one PropertySet"},
    {"name": "quantity_completion_pct", "enabled": true, "group": "BIM Quality",       "alias": "Quantity completion %",   "computed": true,  "ifc_source": "IfcElementQuantity",                      "description": "% of IfcElement with at least one QuantitySet"},
    {"name": "bim_completeness_score",  "enabled": true, "group": "BIM Quality",       "alias": "BIM completeness score",  "computed": true,  "ifc_source": null,                                      "description": "Composite completeness indicator (0-100)"},
    {"name": "complexity_index",        "enabled": true, "group": "Indicators",        "alias": "Complexity index",        "computed": true,  "ifc_source": null,                                      "description": "Entities per storey ratio"},
    {"name": "objects_per_storey",      "enabled": true, "group": "Indicators",        "alias": "Objects per storey",      "computed": true,  "ifc_source": null,                                      "description": "Total objects / storey count"},
    {"name": "objects_per_space",       "enabled": true, "group": "Indicators",        "alias": "Objects per space",       "computed": true,  "ifc_source": null,                                      "description": "Total objects / space count"},
    {"name": "objects_per_m2",          "enabled": true, "group": "Indicators",        "alias": "Objects per m2",          "computed": true,  "ifc_source": null,                                      "description": "Total objects / gross floor area"},
    {"name": "volume_per_m2",           "enabled": true, "group": "Indicators",        "alias": "Volume per m2",           "computed": true,  "ifc_source": null,                                      "description": "Gross volume / gross floor area"},
    {"name": "extractor_version",       "enabled": true, "group": "Extraction",        "alias": "Extractor version",       "computed": false, "ifc_source": null,                                      "description": "Version of the extraction engine"},
    {"name": "extraction_datetime",     "enabled": true, "group": "Extraction",        "alias": "Extraction datetime",     "computed": false, "ifc_source": null,                                      "description": "ISO-8601 datetime of the extraction run"},
    {"name": "extraction_status",       "enabled": true, "group": "Extraction",        "alias": "Extraction status",       "computed": false, "ifc_source": null,                                      "description": "ok or error"},
    {"name": "extraction_error",        "enabled": true, "group": "Extraction",        "alias": "Extraction error",        "computed": false, "ifc_source": null,                                      "description": "Error message when extraction_status = error"}
  ],
  "i18n": {
    "es": {
      "groups": {
        "File":              "Archivo",
        "IFC Header":        "Cabecera IFC",
        "Project":           "Proyecto",
        "Location":          "Ubicacion",
        "Domain":            "Dominio",
        "Spatial Structure": "Estructura espacial",
        "Model Statistics":  "Estadisticas del modelo",
        "Geometry":          "Geometria",
        "Materials":         "Materiales",
        "BIM Quality":       "Calidad BIM",
        "Indicators":        "Indicadores",
        "Extraction":        "Extraccion",
        "Custom":            "Personalizado"
      },
      "fields": {
        "file_name":               {"alias": "Nombre del archivo",           "description": "Nombre del archivo IFC sin ruta"},
        "file_path":               {"alias": "Ruta del archivo",             "description": "Ruta completa al archivo IFC"},
        "document_format":         {"alias": "Formato del documento",        "description": "Siempre IFC"},
        "file_extension":          {"alias": "Extension del archivo",        "description": "Extension del archivo (.ifc, .ifczip, ...)"},
        "file_size_mb":            {"alias": "Tamano del archivo (MB)",      "description": "Tamano del archivo en megabytes"},
        "file_hash":               {"alias": "Hash del archivo (MD5)",       "description": "MD5 de los primeros 64 KB"},
        "file_created":            {"alias": "Fecha de creacion",            "description": "Marca de tiempo de creacion del sistema de archivos"},
        "file_modified":           {"alias": "Fecha de modificacion",        "description": "Marca de tiempo de ultima modificacion"},
        "ifc_version":             {"alias": "Version IFC",                  "description": "Cadena de version del esquema IFC (p.ej. IFC4)"},
        "schema_identifier":       {"alias": "Identificador de esquema",     "description": "Identificador completo del esquema en la cabecera"},
        "file_description":        {"alias": "Descripcion del archivo",      "description": "Descripcion de la cabecera FILE_DESCRIPTION"},
        "file_timestamp":          {"alias": "Marca de tiempo del archivo",  "description": "Marca de tiempo de la cabecera FILE_NAME"},
        "author":                  {"alias": "Autor",                        "description": "Autor(es) de la cabecera FILE_NAME"},
        "organization":            {"alias": "Organizacion",                 "description": "Organizacion de la cabecera FILE_NAME"},
        "originating_system":      {"alias": "Sistema de origen",            "description": "Herramienta BIM / sistema de origen"},
        "preprocessor_version":    {"alias": "Version del preprocesador",    "description": "Version del exportador/preprocesador"},
        "authorization":           {"alias": "Autorizacion",                 "description": "Cadena de autorizacion de FILE_NAME"},
        "project_name":            {"alias": "Nombre del proyecto",          "description": "IfcProject.Name"},
        "project_globalid":        {"alias": "GlobalId del proyecto",        "description": "IfcProject.GlobalId"},
        "project_description":     {"alias": "Descripcion del proyecto",     "description": "IfcProject.Description"},
        "project_phase":           {"alias": "Fase del proyecto",            "description": "IfcProject.Phase"},
        "site_name":               {"alias": "Nombre del emplazamiento",     "description": "IfcSite.Name"},
        "building_name":           {"alias": "Nombre del edificio",          "description": "IfcBuilding.Name"},
        "epsg":                    {"alias": "Codigo EPSG",                  "description": "Codigo EPSG extraido de IfcCoordinateReferenceSystem"},
        "crs_name":                {"alias": "Nombre del SRC",               "description": "IfcCoordinateReferenceSystem.Name"},
        "latitude":                {"alias": "Latitud (grados)",             "description": "IfcSite.RefLatitude convertida a grados decimales"},
        "longitude":               {"alias": "Longitud (grados)",            "description": "IfcSite.RefLongitude convertida a grados decimales"},
        "easting":                 {"alias": "Este (m)",                     "description": "IfcMapConversion.Eastings"},
        "northing":                {"alias": "Norte (m)",                    "description": "IfcMapConversion.Northings"},
        "elevation":               {"alias": "Elevacion (m)",                "description": "IfcMapConversion.OrthogonalHeight"},
        "is_georeferenced":        {"alias": "Esta georreferenciado",        "description": "Verdadero cuando existe IfcMapConversion"},
        "detected_domain":         {"alias": "Dominio detectado",            "description": "Dominio heuristico (Building, Infrastructure, MEP...)"},
        "detected_discipline":     {"alias": "Disciplina detectada",         "description": "Disciplina heuristica segun composicion de clases"},
        "site_count":              {"alias": "Numero de emplazamientos",     "description": "Numero de entidades IfcSite"},
        "building_count":          {"alias": "Numero de edificios",          "description": "Numero de entidades IfcBuilding"},
        "storey_count":            {"alias": "Numero de plantas",            "description": "Numero de entidades IfcBuildingStorey"},
        "space_count":             {"alias": "Numero de espacios",           "description": "Numero de entidades IfcSpace"},
        "zone_count":              {"alias": "Numero de zonas",              "description": "Numero de entidades IfcZone"},
        "system_count":            {"alias": "Numero de sistemas",           "description": "Numero de entidades IfcSystem"},
        "total_entities":          {"alias": "Total de entidades",           "description": "Numero total de entidades en el archivo IFC"},
        "total_objects":           {"alias": "Total de objetos",             "description": "Numero de entidades IfcObject"},
        "total_physical_elements": {"alias": "Total de elementos fisicos",   "description": "Numero de entidades IfcElement"},
        "distinct_ifc_classes":    {"alias": "Clases IFC distintas",         "description": "Numero de tipos de entidad distintos presentes"},
        "bbox_width":              {"alias": "Anchura del encuadre (m)",     "description": "Anchura del encuadre del modelo"},
        "bbox_depth":              {"alias": "Profundidad del encuadre (m)", "description": "Profundidad del encuadre del modelo"},
        "bbox_height":             {"alias": "Altura del encuadre (m)",      "description": "Altura del encuadre del modelo"},
        "footprint_area":          {"alias": "Area de huella (m2)",          "description": "Area de huella proyectada"},
        "gross_floor_area":        {"alias": "Area bruta de planta (m2)",    "description": "Suma de GrossFloorArea de los QuantitySet"},
        "net_floor_area":          {"alias": "Area neta de planta (m2)",     "description": "Suma de NetFloorArea de los QuantitySet"},
        "gross_volume":            {"alias": "Volumen bruto (m3)",           "description": "Volumen bruto total de los QuantitySet"},
        "net_volume":              {"alias": "Volumen neto (m3)",            "description": "Volumen neto total de los QuantitySet"},
        "total_length":            {"alias": "Longitud total (m)",           "description": "Suma de longitudes de todos los elementos lineales"},
        "material_count":          {"alias": "Numero de materiales",         "description": "Numero de entidades IfcMaterial"},
        "dominant_material":       {"alias": "Material dominante",           "description": "Nombre del material mas referenciado"},
        "propertyset_count":       {"alias": "Numero de PropertySet",        "description": "Numero de entidades IfcPropertySet"},
        "quantityset_count":       {"alias": "Numero de QuantitySet",        "description": "Numero de entidades IfcElementQuantity"},
        "classification_count":    {"alias": "Numero de clasificaciones",    "description": "Numero de entidades IfcClassification"},
        "has_geometry":            {"alias": "Tiene geometria",              "description": "Verdadero cuando al menos un elemento tiene geometria"},
        "has_quantities":          {"alias": "Tiene cantidades",             "description": "Verdadero cuando existe al menos un QuantitySet"},
        "has_property_sets":       {"alias": "Tiene PropertySet",            "description": "Verdadero cuando existe al menos un PropertySet"},
        "has_materials":           {"alias": "Tiene materiales",             "description": "Verdadero cuando existe al menos un IfcMaterial"},
        "has_classifications":     {"alias": "Tiene clasificaciones",        "description": "Verdadero cuando existe al menos una IfcClassification"},
        "has_spatial_structure":   {"alias": "Tiene estructura espacial",    "description": "Verdadero cuando el modelo tiene plantas o espacios"},
        "geometry_completion_pct": {"alias": "Completitud de geometria %",   "description": "% de IfcElement con representacion geometrica"},
        "property_completion_pct": {"alias": "Completitud de PropertySet %", "description": "% de IfcElement con al menos un PropertySet"},
        "quantity_completion_pct": {"alias": "Completitud de QuantitySet %", "description": "% de IfcElement con al menos un QuantitySet"},
