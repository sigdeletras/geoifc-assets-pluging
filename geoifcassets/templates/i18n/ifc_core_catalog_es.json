{
  "locale": "es",
  "template": "ifc_core_catalog",
  "groups": {
    "File":              "Archivo",
    "IFC Header":        "Cabecera IFC",
    "Project":           "Proyecto",
    "Location":          "Ubicación",
    "Domain":            "Dominio",
    "Spatial Structure": "Estructura espacial",
    "Model Statistics":  "Estadísticas del modelo",
    "Geometry":          "Geometría",
    "Materials":         "Materiales",
    "BIM Quality":       "Calidad BIM",
    "Indicators":        "Indicadores",
    "Extraction":        "Extracción",
    "Custom":            "Personalizado"
  },
  "fields": {
    "file_name":               {"alias": "Nombre del archivo",           "description": "Nombre del archivo IFC sin ruta"},
    "file_path":               {"alias": "Ruta del archivo",             "description": "Ruta completa al archivo IFC"},
    "document_format":         {"alias": "Formato del documento",        "description": "Siempre IFC"},
    "file_extension":          {"alias": "Extensión del archivo",        "description": "Extensión del archivo (.ifc, .ifczip, …)"},
    "file_size_mb":            {"alias": "Tamaño del archivo (MB)",      "description": "Tamaño del archivo en megabytes"},
    "file_hash":               {"alias": "Hash del archivo (MD5)",       "description": "MD5 de los primeros 64 KB"},
    "file_created":            {"alias": "Fecha de creación",            "description": "Marca de tiempo de creación del sistema de archivos"},
    "file_modified":           {"alias": "Fecha de modificación",        "description": "Marca de tiempo de última modificación"},
    "ifc_version":             {"alias": "Versión IFC",                  "description": "Cadena de versión del esquema IFC (p.ej. IFC4)"},
    "schema_identifier":       {"alias": "Identificador de esquema",     "description": "Identificador completo del esquema en la cabecera"},
    "file_description":        {"alias": "Descripción del archivo",      "description": "Descripción de la cabecera FILE_DESCRIPTION"},
    "file_timestamp":          {"alias": "Marca de tiempo del archivo",  "description": "Marca de tiempo de la cabecera FILE_NAME"},
    "author":                  {"alias": "Autor",                        "description": "Autor(es) de la cabecera FILE_NAME"},
    "organization":            {"alias": "Organización",                 "description": "Organización de la cabecera FILE_NAME"},
    "originating_system":      {"alias": "Sistema de origen",            "description": "Herramienta BIM / sistema de origen"},
    "preprocessor_version":    {"alias": "Versión del preprocesador",    "description": "Versión del exportador/preprocesador"},
    "authorization":           {"alias": "Autorización",                 "description": "Cadena de autorización de FILE_NAME"},
    "project_name":            {"alias": "Nombre del proyecto",          "description": "IfcProject.Name"},
    "project_globalid":        {"alias": "GlobalId del proyecto",        "description": "IfcProject.GlobalId"},
    "project_description":     {"alias": "Descripción del proyecto",     "description": "IfcProject.Description"},
    "project_phase":           {"alias": "Fase del proyecto",            "description": "IfcProject.Phase"},
    "site_name":               {"alias": "Nombre del emplazamiento",     "description": "IfcSite.Name"},
    "building_name":           {"alias": "Nombre del edificio",          "description": "IfcBuilding.Name"},
    "epsg":                    {"alias": "Código EPSG",                  "description": "Código EPSG extraído de IfcCoordinateReferenceSystem"},
    "crs_name":                {"alias": "Nombre del SRC",               "description": "IfcCoordinateReferenceSystem.Name"},
    "latitude":                {"alias": "Latitud (°)",                  "description": "IfcSite.RefLatitude convertida a grados decimales"},
    "longitude":               {"alias": "Longitud (°)",                 "description": "IfcSite.RefLongitude convertida a grados decimales"},
    "easting":                 {"alias": "Este (m)",                     "description": "IfcMapConversion.Eastings"},
    "northing":                {"alias": "Norte (m)",                    "description": "IfcMapConversion.Northings"},
    "elevation":               {"alias": "Elevación (m)",                "description": "IfcMapConversion.OrthogonalHeight"},
    "is_georeferenced":        {"alias": "Está georreferenciado",        "description": "Verdadero cuando existe IfcMapConversion"},
    "detected_domain":         {"alias": "Dominio detectado",            "description": "Dominio heurístico (Building, Infrastructure, MEP…)"},
    "detected_discipline":     {"alias": "Disciplina detectada",         "description": "Disciplina heurística según composición de clases"},
    "site_count":              {"alias": "Número de emplazamientos",     "description": "Número de entidades IfcSite"},
    "building_count":          {"alias": "Número de edificios",          "description": "Número de entidades IfcBuilding"},
    "storey_count":            {"alias": "Número de plantas",            "description": "Número de entidades IfcBuildingStorey"},
    "space_count":             {"alias": "Número de espacios",           "description": "Número de entidades IfcSpace"},
    "zone_count":              {"alias": "Número de zonas",              "description": "Número de entidades IfcZone"},
    "system_count":            {"alias": "Número de sistemas",           "description": "Número de entidades IfcSystem"},
    "total_entities":          {"alias": "Total de entidades",           "description": "Número total de entidades en el archivo IFC"},
    "total_objects":           {"alias": "Total de objetos",             "description": "Número de entidades IfcObject"},
    "total_physical_elements": {"alias": "Total de elementos físicos",   "description": "Número de entidades IfcElement"},
    "distinct_ifc_classes":    {"alias": "Clases IFC distintas",         "description": "Número de tipos de entidad distintos presentes"},
    "bbox_width":              {"alias": "Anchura del encuadre (m)",     "description": "Anchura del encuadre del modelo"},
    "bbox_depth":              {"alias": "Profundidad del encuadre (m)", "description": "Profundidad del encuadre del modelo"},
    "bbox_height":             {"alias": "Altura del encuadre (m)",      "description": "Altura del encuadre del modelo"},
    "footprint_area":          {"alias": "Área de huella (m²)",          "description": "Área de huella proyectada"},
    "gross_floor_area":        {"alias": "Área bruta de planta (m²)",    "description": "Suma de GrossFloorArea de los QuantitySet"},
    "net_floor_area":          {"alias": "Área neta de planta (m²)",     "description": "Suma de NetFloorArea de los QuantitySet"},
    "gross_volume":            {"alias": "Volumen bruto (m³)",           "description": "Volumen bruto total de los QuantitySet"},
    "net_volume":              {"alias": "Volumen neto (m³)",            "description": "Volumen neto total de los QuantitySet"},
    "total_length":            {"alias": "Longitud total (m)",           "description": "Suma de longitudes de todos los elementos lineales"},
    "material_count":          {"alias": "Número de materiales",         "description": "Número de entidades IfcMaterial"},
    "dominant_material":       {"alias": "Material dominante",           "description": "Nombre del material más referenciado"},
    "propertyset_count":       {"alias": "Número de PropertySet",        "description": "Número de entidades IfcPropertySet"},
    "quantityset_count":       {"alias": "Número de QuantitySet",        "description": "Número de entidades IfcElementQuantity"},
    "classification_count":    {"alias": "Número de clasificaciones",    "description": "Número de entidades IfcClassification"},
    "has_geometry":            {"alias": "Tiene geometría",              "description": "Verdadero cuando al menos un elemento tiene geometría"},
    "has_quantities":          {"alias": "Tiene cantidades",             "description": "Verdadero cuando existe al menos un QuantitySet"},
    "has_property_sets":       {"alias": "Tiene PropertySet",            "description": "Verdadero cuando existe al menos un PropertySet"},
    "has_materials":           {"alias": "Tiene materiales",             "description": "Verdadero cuando existe al menos un IfcMaterial"},
    "has_classifications":     {"alias": "Tiene clasificaciones",        "description": "Verdadero cuando existe al menos una IfcClassification"},
    "has_spatial_structure":   {"alias": "Tiene estructura espacial",    "description": "Verdadero cuando el modelo tiene plantas o espacios"},
    "geometry_completion_pct": {"alias": "Completitud de geometría %",   "description": "% de IfcElement con representación geométrica"},
    "property_completion_pct": {"alias": "Completitud de PropertySet %", "description": "% de IfcElement con al menos un PropertySet"},
    "quantity_completion_pct": {"alias": "Completitud de QuantitySet %", "description": "% de IfcElement con al menos un QuantitySet"},
    "bim_completeness_score":  {"alias": "Puntuación de completitud BIM","description": "Indicador compuesto de completitud (0–100)"},
    "complexity_index":        {"alias": "Índice de complejidad",        "description": "Ratio entidades/planta"},
    "objects_per_storey":      {"alias": "Objetos por planta",           "description": "Total de objetos / número de plantas"},
    "objects_per_space":       {"alias": "Objetos por espacio",          "description": "Total de objetos / número de espacios"},
    "objects_per_m2":          {"alias": "Objetos por m²",               "description": "Total de objetos / área bruta de planta"},
    "volume_per_m2":           {"alias": "Volumen por m²",               "description": "Volumen bruto / área bruta de planta"},
    "extractor_version":       {"alias": "Versión del extractor",        "description": "Versión del motor de extracción"},
    "extraction_datetime":     {"alias": "Fecha y hora de extracción",   "description": "Fecha y hora de la extracción en formato ISO-8601"},
    "extraction_status":       {"alias": "Estado de extracción",         "description": "ok o error"},
    "extraction_error":        {"alias": "Error de extracción",          "description": "Mensaje de error cuando extraction_status = error"}
  }
}
