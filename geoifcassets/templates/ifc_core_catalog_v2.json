{
  "template_name": "ifc_core_catalog_v2",
  "extractor_version": "1.1.0",
  "description": "Extended template — one CSV row per IFC file with external metadata, IFC attributes, Quantity Sets, selected asset-level Property Sets, classifications and computed quality indicators.",
  "metadata": {
    "author": "GeoInnova",
    "contact": "patricio.soriano@geoinnova.org",
    "created_at": "2026-06-26",
    "updated_at": "2026-06-30",
    "template_version": "2.0.0",
    "min_extractor_version": "1.1.0",
    "ifc_versions": [
      "IFC2X3",
      "IFC4",
      "IFC4X3"
    ],
    "language": "en",
    "license": "proprietary",
    "tags": [
      "Asset",
      "BIM",
      "Classification",
      "GIS",
      "IFC",
      "PSET",
      "QGIS",
      "QTO",
      "catalog"
    ]
  },
  "fields": [
    {
      "name": "file_name",
      "enabled": true,
      "group": "File",
      "alias": "File name",
      "computed": false,
      "ifc_source": null,
      "description": "IFC filename without path",
      "source_type": "external_metadata"
    },
    {
      "name": "file_path",
      "enabled": true,
      "group": "File",
      "alias": "File path",
      "computed": false,
      "ifc_source": null,
      "description": "Full path to the IFC file",
      "source_type": "external_metadata"
    },
    {
      "name": "document_format",
      "enabled": true,
      "group": "File",
      "alias": "Document format",
      "computed": false,
      "ifc_source": null,
      "description": "Always IFC",
      "source_type": "external_metadata"
    },
    {
      "name": "file_extension",
      "enabled": true,
      "group": "File",
      "alias": "File extension",
      "computed": false,
      "ifc_source": null,
      "description": "File extension (.ifc, .ifczip, ...)",
      "source_type": "external_metadata"
    },
    {
      "name": "file_size_mb",
      "enabled": true,
      "group": "File",
      "alias": "File size (MB)",
      "computed": false,
      "ifc_source": null,
      "description": "File size in megabytes",
      "source_type": "external_metadata"
    },
    {
      "name": "file_hash",
      "enabled": true,
      "group": "File",
      "alias": "File hash (MD5)",
      "computed": true,
      "ifc_source": null,
      "description": "MD5 of the first 64 KB",
      "source_type": "computed"
    },
    {
      "name": "file_created",
      "enabled": true,
      "group": "File",
      "alias": "File created",
      "computed": false,
      "ifc_source": null,
      "description": "Filesystem creation timestamp",
      "source_type": "external_metadata"
    },
    {
      "name": "file_modified",
      "enabled": true,
      "group": "File",
      "alias": "File modified",
      "computed": false,
      "ifc_source": null,
      "description": "Filesystem last-modified timestamp",
      "source_type": "external_metadata"
    },
    {
