      "description": "Timestamp from FILE_NAME header",
      "source_type": "ifc_attribute"
    },
    {
      "name": "author",
      "enabled": true,
      "group": "IFC Header",
      "alias": "Author",
      "computed": false,
      "ifc_source": "FILE_NAME.author",
      "description": "Author(s) from FILE_NAME header",
      "source_type": "ifc_attribute"
    },
    {
      "name": "organization",
      "enabled": true,
      "group": "IFC Header",
      "alias": "Organization",
      "computed": false,
      "ifc_source": "FILE_NAME.organization",
      "description": "Organization from FILE_NAME header",
      "source_type": "ifc_attribute"
    },
    {
      "name": "originating_system",
      "enabled": true,
      "group": "IFC Header",
      "alias": "Originating system",
      "computed": false,
      "ifc_source": "FILE_NAME.originating_system",
      "description": "Authoring tool / originating system",
      "source_type": "ifc_attribute"
    },
    {
      "name": "preprocessor_version",
      "enabled": true,
      "group": "IFC Header",
      "alias": "Preprocessor version",
      "computed": false,
      "ifc_source": "FILE_NAME.preprocessor_version",
      "description": "Preprocessor/exporter version",
