    },
    {
      "name": "authorization",
      "enabled": true,
      "group": "IFC Header",
      "alias": "Authorization",
      "computed": false,
      "ifc_source": "FILE_NAME.authorization",
      "description": "Authorization string from FILE_NAME",
      "source_type": "ifc_attribute"
    },
    {
      "name": "project_name",
      "enabled": true,
      "group": "Project",
      "alias": "Project name",
      "computed": false,
      "ifc_source": "IfcProject.Name",
      "description": "IfcProject.Name",
      "source_type": "ifc_attribute"
    },
    {
      "name": "project_globalid",
      "enabled": true,
      "group": "Project",
      "alias": "Project GlobalId",
      "computed": false,
      "ifc_source": "IfcProject.GlobalId",
      "description": "IfcProject.GlobalId",
      "source_type": "ifc_attribute"
    },
    {
      "name": "project_description",
      "enabled": true,
      "group": "Project",
      "alias": "Project description",
      "computed": false,
      "ifc_source": "IfcProject.Description",
      "description": "IfcProject.Description",
      "source_type": "ifc_attribute"
    },
    {
      "name": "project_phase",
      "enabled": true,
      "group": "Project",
      "alias": "Project phase",
      "computed": false,
      "ifc_source": "IfcProject.Phase",
      "description": "IfcProject.Phase",
      "source_type": "ifc_attribute"
    },
    {
      "name": "site_name",
      "enabled": true,
      "group": "Location",
      "alias": "Site name",
      "computed": false,
      "ifc_source": "IfcSite.Name",
      "description": "IfcSite.Name",
      "source_type": "ifc_attribute"
    },
    {
      "name": "building_name",
      "enabled": true,
      "group": "Location",
      "alias": "Building name",
      "computed": false,
      "ifc_source": "IfcBuilding.Name",
      "ifc4x3_note": "IfcBuilding deprecated in IFC4X3; extractor falls back to IfcFacility",
      "description": "IfcBuilding.Name",
      "source_type": "ifc_attribute"
    },
    {
      "name": "epsg",
      "enabled": true,
      "group": "Location",
      "alias": "EPSG code",
      "computed": true,
      "ifc_source": "IfcCoordinateReferenceSystem",
      "min_ifc_version": "IFC4",
      "description": "EPSG code parsed from IfcCoordinateReferenceSystem",
      "source_type": "computed"
    },
    {
      "name": "crs_name",
      "enabled": true,
      "group": "Location",
      "alias": "CRS name",
      "computed": false,
      "ifc_source": "IfcCoordinateReferenceSystem.Name",
      "min_ifc_version": "IFC4",
      "description": "IfcCoordinateReferenceSystem.Name",
      "source_type": "ifc_attribute"
    },
    {
      "name": "latitude",
      "enabled": true,
      "group": "Location",
      "alias": "Latitude (deg)",
      "computed": true,
      "ifc_source": "IfcSite.RefLatitude",
      "description": "IfcSite.RefLatitude converted to decimal degrees",
      "source_type": "computed"
    },
    {
      "name": "longitude",
      "enabled": true,
      "group": "Location",
      "alias": "Longitude (deg)",
      "computed": true,
      "ifc_source": "IfcSite.RefLongitude",
      "description": "IfcSite.RefLongitude converted to decimal degrees",
      "source_type": "computed"
    },
    {
      "name": "easting",
      "enabled": true,
      "group": "Location",
      "alias": "Easting (m)",
      "computed": false,
      "ifc_source": "IfcMapConversion.Eastings",
      "min_ifc_version": "IFC4",
      "description": "IfcMapConversion.Eastings",
      "source_type": "ifc_attribute"
    },
    {
      "name": "northing",
      "enabled": true,
      "group": "Location",
      "alias": "Northing (m)",
      "computed": false,
      "ifc_source": "IfcMapConversion.Northings",
      "min_ifc_version": "IFC4",
      "description": "IfcMapConversion.Northings",
      "source_type": "ifc_attribute"
    },
    {
      "name": "elevation",
      "enabled": true,
      "group": "Location",
      "alias": "Elevation (m)",
      "computed": false,
      "ifc_source": "IfcMapConversion.OrthogonalHeight",
      "min_ifc_version": "IFC4",
      "description": "IfcMapConversion.OrthogonalHeight",
      "source_type": "ifc_attribute"
    },
    {
      "name": "is_georeferenced",
      "enabled": true,
      "group": "Location",
      "alias": "Is georeferenced",
      "computed": true,
      "ifc_source": "IfcMapConversion",
      "min_ifc_version": "IFC4",
      "description": "True when IfcMapConversion is present",
      "source_type": "computed"
    },
    {
      "name": "detected_domain",
      "enabled": true,
      "group": "Domain",
      "alias": "Detected domain",
      "computed": true,
      "ifc_source": null,
      "description": "Heuristic domain (Building, Infrastructure, MEP...)",
      "source_type": "computed"
    },
    {
      "name": "detected_discipline",
      "enabled": true,
      "group": "Domain",
      "alias": "Detected discipline",
      "computed": true,
      "ifc_source": null,
      "description": "Heuristic discipline from class composition",
      "source_type": "computed"
    },
    {
      "name": "site_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "Site count",
      "computed": true,
      "ifc_source": "IfcSite",
      "description": "Number of IfcSite entities",
      "source_type": "computed"
    },
    {
      "name": "building_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "Building count",
      "computed": true,
      "ifc_source": "IfcBuilding",
      "ifc4x3_note": "IfcBuilding deprecated in IFC4X3; count includes IfcFacility subtypes",
      "description": "Number of IfcBuilding entities",
      "source_type": "computed"
    },
    {
      "name": "storey_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "Storey count",
      "computed": true,
      "ifc_source": "IfcBuildingStorey",
      "ifc4x3_note": "IfcBuildingStorey deprecated in IFC4X3; extractor falls back to IfcFacilityPart",
      "description": "Number of IfcBuildingStorey entities",
      "source_type": "computed"
    },
    {
      "name": "space_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "Space count",
      "computed": true,
      "ifc_source": "IfcSpace",
      "description": "Number of IfcSpace entities",
      "source_type": "computed"
    },
    {
      "name": "zone_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "Zone count",
      "computed": true,
      "ifc_source": "IfcZone",
      "description": "Number of IfcZone entities",
      "source_type": "computed"
    },
    {
      "name": "system_count",
      "enabled": true,
      "group": "Spatial Structure",
      "alias": "System count",
      "computed": true,
      "ifc_source": "IfcSystem",
      "description": "Number of IfcSystem entities",
      "source_type": "computed"
    },
    {
      "name": "total_entities",
      "enabled": true,
      "group": "Model Statistics",
      "alias": "Total entities",
      "computed": true,
      "ifc_source": null,
      "description": "Total entity count in the IFC file",
      "source_type": "computed"
    },
    {
      "name": "total_objects",
      "enabled": true,
      "group": "Model Statistics",
      "alias": "Total objects",
      "computed": true,
      "ifc_source": "IfcObject",
      "description": "Number of IfcObject entities",
      "source_type": "computed"
    },
    {
      "name": "total_physical_elements",
      "enabled": true,
      "group": "Model Statistics",
      "alias": "Total physical elements",
      "computed": true,
      "ifc_source": "IfcElement",
      "description": "Number of IfcElement entities",
      "source_type": "computed"
    },
    {
      "name": "distinct_ifc_classes",
      "enabled": true,
      "group": "Model Statistics",
      "alias": "Distinct IFC classes",
      "computed": true,
      "ifc_source": null,
      "description": "Number of distinct entity types present",
      "source_type": "computed"
    },
    {
      "name": "bbox_width",
      "enabled": true,
      "group": "Geometry",
      "alias": "Bounding box width (m)",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "Model bounding box width",
      "source_type": "computed"
    },
    {
      "name": "bbox_depth",
      "enabled": true,
      "group": "Geometry",
      "alias": "Bounding box depth (m)",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "Model bounding box depth",
      "source_type": "computed"
    },
    {
      "name": "bbox_height",
      "enabled": true,
      "group": "Geometry",
      "alias": "Bounding box height (m)",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "Model bounding box height",
      "source_type": "computed"
    },
    {
      "name": "footprint_area",
      "enabled": true,
      "group": "Geometry",
      "alias": "Footprint area (m2)",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "Projected footprint area",
      "source_type": "computed"
    },
    {
      "name": "gross_floor_area",
      "enabled": true,
      "group": "Geometry",
      "alias": "Gross floor area (m2)",
      "computed": true,
      "ifc_source": "IfcElementQuantity.GrossFloorArea",
      "description": "Sum of GrossFloorArea from QuantitySets",
      "source_type": "quantity"
    },
    {
      "name": "net_floor_area",
      "enabled": true,
      "group": "Geometry",
      "alias": "Net floor area (m2)",
      "computed": true,
      "ifc_source": "IfcElementQuantity.NetFloorArea",
      "description": "Sum of NetFloorArea from QuantitySets",
      "source_type": "quantity"
    },
    {
      "name": "gross_volume",
      "enabled": true,
      "group": "Geometry",
      "alias": "Gross volume (m3)",
      "computed": true,
      "ifc_source": "IfcElementQuantity.GrossVolume",
      "description": "Total gross volume from QuantitySets",
      "source_type": "quantity"
    },
    {
      "name": "net_volume",
      "enabled": true,
      "group": "Geometry",
      "alias": "Net volume (m3)",
      "computed": true,
      "ifc_source": "IfcElementQuantity.NetVolume",
      "description": "Total net volume from QuantitySets",
      "source_type": "quantity"
    },
    {
      "name": "total_length",
      "enabled": true,
      "group": "Geometry",
      "alias": "Total length (m)",
      "computed": true,
      "ifc_source": "IfcElementQuantity.Length",
      "description": "Sum of all linear element lengths",
      "source_type": "quantity"
    },
    {
      "name": "material_count",
      "enabled": true,
      "group": "Materials",
      "alias": "Material count",
      "computed": true,
      "ifc_source": "IfcMaterial",
      "description": "Number of IfcMaterial entities",
      "source_type": "computed"
    },
    {
      "name": "dominant_material",
      "enabled": true,
      "group": "Materials",
      "alias": "Dominant material",
      "computed": true,
      "ifc_source": "IfcMaterial.Name",
      "description": "Most frequently referenced material name",
      "source_type": "computed"
    },
    {
      "name": "propertyset_count",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "PropertySet count",
      "computed": true,
      "ifc_source": "IfcPropertySet",
      "description": "Number of IfcPropertySet entities",
      "source_type": "computed"
    },
    {
      "name": "quantityset_count",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "QuantitySet count",
      "computed": true,
      "ifc_source": "IfcElementQuantity",
      "description": "Number of IfcElementQuantity entities",
      "source_type": "quantity"
    },
    {
      "name": "classification_count",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Classification count",
      "computed": true,
      "ifc_source": "IfcClassification",
      "description": "Number of IfcClassification entities",
      "source_type": "computed"
    },
    {
      "name": "has_geometry",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has geometry",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "True when at least one element has geometry",
      "source_type": "computed"
    },
    {
      "name": "has_quantities",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has quantities",
      "computed": true,
      "ifc_source": "IfcElementQuantity",
      "description": "True when at least one QuantitySet exists",
      "source_type": "quantity"
    },
    {
      "name": "has_property_sets",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has property sets",
      "computed": true,
      "ifc_source": "IfcPropertySet",
      "description": "True when at least one PropertySet exists",
      "source_type": "computed"
    },
    {
      "name": "has_materials",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has materials",
      "computed": true,
      "ifc_source": "IfcMaterial",
      "description": "True when at least one IfcMaterial exists",
      "source_type": "computed"
    },
    {
      "name": "has_classifications",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has classifications",
      "computed": true,
      "ifc_source": "IfcClassification",
      "description": "True when at least one IfcClassification exists",
      "source_type": "computed"
    },
    {
      "name": "has_spatial_structure",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Has spatial structure",
      "computed": true,
      "ifc_source": "IfcBuildingStorey | IfcSpace",
      "description": "True when the model has storeys or spaces",
      "source_type": "computed"
    },
    {
      "name": "geometry_completion_pct",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Geometry completion %",
      "computed": true,
      "ifc_source": "IfcShapeRepresentation",
      "description": "% of IfcElement with geometry representation",
      "source_type": "computed"
    },
    {
      "name": "property_completion_pct",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Property completion %",
      "computed": true,
      "ifc_source": "IfcRelDefinesByProperties",
      "description": "% of IfcElement with at least one PropertySet",
      "source_type": "computed",
      "entity_base": "IfcElement",
      "entity_base_note": "Base is IfcElement (physical elements only). See pct_objects_with_psets for IfcObject-based equivalent."
    },
    {
      "name": "quantity_completion_pct",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "Quantity completion %",
      "computed": true,
      "ifc_source": "IfcElementQuantity",
      "description": "% of IfcElement with at least one QuantitySet",
      "source_type": "quantity"
    },
    {
      "name": "bim_completeness_score",
      "enabled": true,
      "group": "BIM Quality",
      "alias": "BIM completeness score",
      "computed": true,
      "ifc_source": null,
      "description": "Composite completeness indicator (0-100)",
      "source_type": "computed",
      "formula_note": "Weighted average: geometry_completion_pct*0.3 + property_completion_pct*0.3 + quantity_completion_pct*0.2 + (has_classifications*10) + (has_materials*10). Extractor must implement this formula explicitly."
    },
    {
      "name": "complexity_index",
      "enabled": true,
      "group": "Indicators",
      "alias": "Complexity index",
      "computed": true,
      "ifc_source": null,
      "description": "Entities per storey ratio",
      "source_type": "computed"
    },
    {
      "name": "objects_per_storey",
      "enabled": true,
      "group": "Indicators",
      "alias": "Objects per storey",
      "computed": true,
      "ifc_source": null,
      "description": "Total objects / storey count",
      "source_type": "computed"
    },
    {
      "name": "objects_per_space",
      "enabled": true,
      "group": "Indicators",
      "alias": "Objects per space",
      "computed": true,
      "ifc_source": null,
      "description": "Total objects / space count",
      "source_type": "computed"
    },
    {
      "name": "objects_per_m2",
      "enabled": true,
      "group": "Indicators",
      "alias": "Objects per m2",
      "computed": true,
      "ifc_source": null,
      "description": "Total objects / gross floor area",
      "source_type": "computed"
    },
    {
      "name": "volume_per_m2",
      "enabled": true,
      "group": "Indicators",
      "alias": "Volume per m2",
      "computed": true,
      "ifc_source": null,
      "description": "Gross volume / gross floor area",
      "source_type": "computed"
    },
    {
      "name": "extractor_version",
      "enabled": true,
      "group": "Extraction",
      "alias": "Extractor version",
      "computed": false,
      "ifc_source": null,
      "description": "Version of the extraction engine",
      "source_type": "external_metadata"
    },
    {
      "name": "extraction_datetime",
      "enabled": true,
      "group": "Extraction",
      "alias": "Extraction datetime",
      "computed": false,
      "ifc_source": null,
      "description": "ISO-8601 datetime of the extraction run",
      "source_type": "external_metadata"
    },
    {
      "name": "extraction_status",
      "enabled": true,
      "group": "Extraction",
      "alias": "Extraction status",
      "computed": false,
      "ifc_source": null,
      "description": "ok or error",
